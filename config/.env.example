# ── Base de Datos ──────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_NAME=perudata_api
DB_USER=perudata_user
DB_PASS=tu_password_seguro

# ── Admin Panel ────────────────────────────────
ADMIN_SESSION_SECRET=cambia_esto_por_un_string_random_largo

# ── Alertas ────────────────────────────────────
ADMIN_EMAIL=admin@tudominio.com
SLACK_WEBHOOK=

# ── APIs de Respaldo ───────────────────────────
# apis.net.pe — DNI primario y RUC backup (gratis con límites, o pago sin límites)
BACKUP_API_KEY=tu_key_de_apis_net_pe
# apiperu.dev — DNI secundario (opcional, requiere registro)
APIPERU_KEY=

# ── App ────────────────────────────────────────
APP_ENV=production
APP_URL=https://api.tudominio.com
APP_DEBUG=false
