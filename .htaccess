Options -Indexes

RewriteEngine On

# ── CRÍTICO: pasar el header Authorization a PHP-FPM (Plesk/Apache lo bloquea por defecto)
RewriteRule .* - [E=HTTP_AUTHORIZATION:%{HTTP:Authorization}]
SetEnvIf Authorization "(.*)" HTTP_AUTHORIZATION=$1

# Forzar HTTPS
RewriteCond %{HTTPS} off
RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# Páginas públicas en /public/
RewriteRule ^playground\.php$ public/playground.php [QSA,L]
RewriteRule ^docs\.php$ public/docs.php [QSA,L]

# Rutas de la API y health → public/index.php
RewriteRule ^(api|health)(/.*)?$ public/index.php [QSA,L]

# Bloquear acceso directo a directorios internos
RewriteRule ^(src|config|cron|database|vendor|logs)/ - [F,L]

# Headers de seguridad
Header always set X-Content-Type-Options "nosniff"
Header always set X-Frame-Options "SAMEORIGIN"
Header always set X-XSS-Protection "1; mode=block"
Header always set Referrer-Policy "strict-origin-when-cross-origin"

# Proteger archivos sensibles
<FilesMatch "^(\.env|composer\.json|composer\.lock|schema\.sql)$">
    Order allow,deny
    Deny from all
</FilesMatch>
